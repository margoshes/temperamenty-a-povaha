      </div>
    `).join("");

    setTimeout(() => {
      items.forEach(([, pct], i) => {
        const bar = document.getElementById(`bar${i}`);
        if(bar) bar.style.width = pct + "%";
      });
    }, 80);
  }

  function openResult(){
    document.getElementById("resultOverlay").classList.add("show");
    playRevealSound();
  }

  function closeResult(){
    document.getElementById("resultOverlay").classList.remove("show");
  }

  function resetCurrentMode(){
    if(mode === "traits"){
      selectedTraits.clear();
      document.querySelectorAll(".trait-btn").forEach(btn => btn.classList.remove("selected"));
    } else {
      Object.keys(selectedSituationAnswers).forEach(k => delete selectedSituationAnswers[k]);
      document.querySelectorAll(".situation-options button").forEach(btn => btn.classList.remove("selected"));
    }
    closeResult();
  }

  function playRevealSound(){
    const Ctx = window.AudioContext || window.webkitAudioContext;
    if(!Ctx) return;
    const ctx = new Ctx();
    const now = ctx.currentTime;
    [523.25, 659.25, 783.99].forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = "sine";
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.linearRampToValueAtTime(0.08, now + 0.08 + i*0.03);
      gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.6 + i*0.05);
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.start(now + i*0.05);
      osc.stop(now + 0.7 + i*0.05);
    });
  }

  const modeToggle = document.getElementById("modeToggle");
  const labelTraits = document.getElementById("labelTraits");
  const labelSituations = document.getElementById("labelSituations");
  const traitsPanel = document.getElementById("traitsPanel");
  const situationsPanel = document.getElementById("situationsPanel");
  const mainSectionTitle = document.getElementById("mainSectionTitle");

  modeToggle.addEventListener("change", () => {
    if(modeToggle.checked){
      mode = "situations";
      labelTraits.classList.remove("active");
      labelSituations.classList.add("active");
      traitsPanel.style.display = "none";
      situationsPanel.style.display = "block";
      mainSectionTitle.textContent = "Reaguj na situace a odhal svůj klasický temperament";
    } else {
      mode = "traits";
      labelSituations.classList.remove("active");
      labelTraits.classList.add("active");
      situationsPanel.style.display = "none";
      traitsPanel.style.display = "block";
      mainSectionTitle.textContent = "Vyber rysy, které tě nejvíc vystihují";
    }
  });
</script>
</body>
</html>
