<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Temperament a rysy povahy</title>
<style>
  :root{
    --gold:#d8b86b;
    --gold-2:#f1dfb2;
    --paper:#efe5cb;
    --text:#f6f0df;
    --muted:#d9d0b7;
    --shadow:0 18px 44px rgba(0,0,0,.42);
    --bg1:#08111c;
    --bg2:#0d1724;

    --leader:#ff6b6b;
    --social:#ffd166;
    --calm:#7dd48a;
    --deep:#8ea6ff;
    --creator:#c792ea;
    --steady:#7ad7f0;

    --chol:#ff5c5c;
    --sang:#ffd84d;
    --phleg:#5ec8ff;
    --mel:#8b7cff;
  }

  *{box-sizing:border-box}
  html,body{margin:0;padding:0}

  body{
    min-height:100vh;
    font-family:Georgia, "Times New Roman", serif;
    color:var(--text);
    background:
      radial-gradient(circle at 50% 0%, rgba(255,220,120,.08), transparent 22%),
      linear-gradient(180deg, #0a111a, #081019 45%, #071018);
    overflow-x:hidden;
  }

  .header-image{
    position:relative;
    height:420px;
    background:
      linear-gradient(rgba(4,8,15,.18), rgba(4,8,15,.45)),
      url("header.png") center center / cover no-repeat;
    box-shadow:0 24px 60px rgba(0,0,0,.45);
  }

  .header-overlay{
    position:absolute;
    inset:0;
    background:
      radial-gradient(circle at 70% 18%, rgba(255,220,120,.10), transparent 18%),
      linear-gradient(to bottom, rgba(0,0,0,.03), rgba(0,0,0,.35));
    pointer-events:none;
  }

  .sparkles{
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:0;
    overflow:hidden;
  }

  .sparkle{
    position:absolute;
    width:4px;
    height:4px;
    border-radius:50%;
    background:#f7e3a4;
    box-shadow:0 0 10px rgba(247,227,164,.9);
    animation:twinkle 4s ease-in-out infinite;
    opacity:.8;
  }

  .wrap{
    position:relative;
    z-index:1;
    max-width:1220px;
    margin:0 auto;
    padding:24px 18px 46px;
  }

  .hero{
    text-align:center;
    padding:16px 10px 10px;
    margin-top:-40px;
  }

  h1{
    margin:0;
    color:var(--gold);
    font-size:clamp(2rem,4vw,3.5rem);
    text-shadow:0 3px 18px rgba(0,0,0,.38);
  }

  .subtitle{
    margin:14px auto 0;
    max-width:840px;
    color:var(--gold-2);
    background:linear-gradient(180deg, rgba(14,22,34,.9), rgba(9,15,24,.96));
    border:1px solid rgba(216,184,107,.24);
    border-radius:999px;
    padding:12px 18px;
    box-shadow:0 12px 26px rgba(0,0,0,.28);
  }

  .mode-switch-wrap{
    display:flex;
    justify-content:center;
    align-items:center;
    gap:14px;
    margin-top:24px;
    flex-wrap:wrap;
  }

  .mode-label{
    color:var(--gold-2);
    font-weight:700;
    opacity:.65;
    transition:all .35s ease;
  }

  .mode-label.active{
    opacity:1;
    transform:scale(1.03);
    text-shadow:0 0 14px rgba(255,215,120,.45);
  }

  .mode-toggle{
    position:relative;
    width:88px;
    height:42px;
    display:inline-block;
  }

  .mode-toggle input{display:none}

  .mode-slider{
    position:absolute;
    inset:0;
    border-radius:999px;
    background:linear-gradient(180deg, rgba(14,22,34,.95), rgba(9,15,24,.98));
    border:1px solid rgba(216,184,107,.32);
    box-shadow:0 0 18px rgba(216,184,107,.10), inset 0 0 12px rgba(255,255,255,.03);
    cursor:pointer;
    transition:all .35s ease;
  }

  .mode-slider::before{
    content:"";
    position:absolute;
    width:30px;
    height:30px;
    left:6px;
    top:5px;
    border-radius:50%;
    background:linear-gradient(180deg, #ead8a7, #cdaa57);
    box-shadow:0 0 12px rgba(255,215,120,.35);
    transition:all .35s ease;
  }

  .mode-toggle input:checked + .mode-slider{
    background:linear-gradient(180deg, rgba(18,34,28,.96), rgba(8,22,16,.98));
    border-color:rgba(125,212,138,.42);
    box-shadow:0 0 22px rgba(125,212,138,.22), inset 0 0 12px rgba(255,255,255,.03);
  }

  .mode-toggle input:checked + .mode-slider::before{
    transform:translateX(44px);
    background:linear-gradient(180deg, #d7f0dc, #8dc99e);
    box-shadow:0 0 16px rgba(125,212,138,.45);
  }

  .section-title{
    margin:30px 0 14px;
    text-align:center;
    color:var(--gold-2);
    font-size:1.8rem;
  }

  .panel{
    background:linear-gradient(180deg, rgba(7,13,21,.78), rgba(6,12,20,.86));
    border:2px solid rgba(187,204,226,.38);
    border-radius:20px;
    box-shadow:var(--shadow);
    padding:18px;
    backdrop-filter:blur(5px);
  }

  .traits-panel{display:block; animation:fadeSoft .35s ease;}
  .situations-panel{display:none; animation:fadeSoft .35s ease;}

  .traits-grid{
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    gap:14px;
  }

  .trait-btn{
    padding:16px 14px;
    border-radius:16px;
    background:linear-gradient(180deg, rgba(29,43,61,.96), rgba(16,27,41,.98));
    color:#f4ecd3;
    border:1px solid rgba(216,184,107,.18);
    font-size:1rem;
    min-height:68px;
  }

  .trait-btn.selected{
    background:linear-gradient(180deg, rgba(215,240,220,.98), rgba(141,201,158,.96));
    color:#10261a;
    border:1px solid rgba(125,212,138,.65);
    box-shadow:0 0 20px rgba(125,212,138,.35);
  }

  .trait-info{
    margin:12px 0 0;
    color:var(--muted);
    text-align:center;
  }

  .situations-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:22px;
  }

  .card{
    background:linear-gradient(180deg, rgba(7,13,21,.78), rgba(6,12,20,.86));
    border:2px solid rgba(187,204,226,.52);
    border-radius:18px;
    overflow:hidden;
    box-shadow:var(--shadow);
    transition:transform .22s ease, box-shadow .22s ease, border-color .22s ease;
  }

  .card:hover{
    transform:translateY(-6px);
    box-shadow:0 24px 58px rgba(0,0,0,.45), 0 0 28px rgba(216,184,107,.10);
    border-color:rgba(216,184,107,.42);
  }

  .card-head{
    display:grid;
    grid-template-columns:1.1fr .9fr;
    min-height:220px;
    border-bottom:1px solid rgba(229,208,151,.16);
    background:
      linear-gradient(rgba(0,0,0,.08), rgba(0,0,0,.24)),
      linear-gradient(135deg, rgba(52,40,28,.78), rgba(18,40,41,.78));
  }

  .head-text{padding:16px 18px 12px}

  .eyebrow{
    display:flex;
    align-items:center;
    gap:10px;
    color:var(--gold-2);
    font-size:.96rem;
    margin-bottom:8px;
  }

  .icon-chip{
    width:28px;
    height:28px;
    border-radius:50%;
    display:grid;
    place-items:center;
    background:rgba(216,184,107,.16);
    border:1px solid rgba(216,184,107,.36);
    box-shadow:0 0 16px rgba(216,184,107,.10);
    flex:0 0 auto;
  }

  .card h3{
    margin:0 0 8px;
    color:var(--gold-2);
    font-size:1.35rem;
    line-height:1.16;
  }

  .question{
    font-size:1rem;
    color:#f4ecd3;
    margin-bottom:10px;
    line-height:1.5;
  }

  .situation-options{
    display:block;
    margin-top:10px;
  }

  .situation-options button{
    display:block;
    width:100%;
    margin:7px 0;
    text-align:left;
    padding:11px 14px;
    background:linear-gradient(180deg, rgba(29,43,61,.96), rgba(16,27,41,.98));
    color:#f4ecd3;
    border:1px solid rgba(216,184,107,.18);
  }

  .situation-options button.selected{
    background:linear-gradient(180deg, #fff1bf, #ffd166);
    color:#2d2208;
    border:1px solid rgba(255,216,77,.75);
    box-shadow:0 0 20px rgba(255,216,77,.32);
  }

  .art{
    display:grid;
    place-items:center;
    padding:10px;
    border-left:1px solid rgba(229,208,151,.14);
    background:
      radial-gradient(circle at 70% 30%, rgba(255,220,140,.12), transparent 26%),
      linear-gradient(135deg, rgba(23,34,45,.95), rgba(58,41,24,.92));
  }

  .art svg{
    width:100%;
    height:100%;
    max-height:200px;
    display:block;
    filter:drop-shadow(0 12px 18px rgba(0,0,0,.30));
  }

  .actions{
    text-align:center;
    margin-top:28px;
  }

  .help-box{
    margin-top:24px;
    padding:18px 20px;
    background:rgba(8,14,20,.72);
    border:1px solid rgba(187,203,220,.35);
    border-radius:16px;
    box-shadow:var(--shadow);
  }

  .help-box h3{
    color:var(--gold);
    margin:0 0 10px;
  }

  .help-box p, .help-box li{
    color:var(--muted);
    line-height:1.7;
  }

  .result-overlay{
    position:fixed;
    inset:0;
    background:rgba(5,10,18,.82);
    backdrop-filter:blur(6px);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:9999;
    padding:20px;
  }

  .result-overlay.show{
    display:flex;
    animation:fadeIn .5s ease;
  }

  .result-box{
    width:min(940px, 96vw);
    background:linear-gradient(180deg, rgba(10,18,29,.96), rgba(7,12,20,.98));
    border:2px solid rgba(216,184,107,.45);
    border-radius:22px;
    box-shadow:0 0 40px rgba(216,184,107,.18), 0 24px 60px rgba(0,0,0,.45);
    padding:28px 24px;
    text-align:center;
    color:#f6f0df;
    animation:prophecyRise .7s ease;
  }

  .result-box h2{
    color:#f1dfb2;
    font-size:2rem;
    margin:0 0 18px;
  }

  .wheel-wrap{
    display:flex;
    justify-content:center;
    margin:10px 0 22px;
  }

  .magic-wheel{
    width:270px;
    height:270px;
    border-radius:50%;
    position:relative;
    box-shadow:
      0 0 30px rgba(255,255,255,.06),
      0 0 40px rgba(216,184,107,.12);
  }

  .magic-wheel::after{
    content:"";
    position:absolute;
    inset:20px;
    border-radius:50%;
    background:rgba(8,14,20,.92);
    box-shadow:inset 0 0 25px rgba(255,255,255,.04);
  }

  .magic-wheel-center{
    position:absolute;
    inset:0;
    display:flex;
    align-items:center;
    justify-content:center;
    z-index:2;
    flex-direction:column;
    font-weight:700;
    padding:0 34px;
    text-align:center;
  }

  .magic-wheel-center .main-role{
    color:#f1dfb2;
    font-size:1.12rem;
    line-height:1.25;
  }

  .magic-wheel-center .small{
    color:#d9d0b7;
    font-size:.9rem;
    margin-top:6px;
  }

  .stats{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:16px;
    margin-top:18px;
    text-align:left;
  }

  .stat{
    background:rgba(255,255,255,.04);
    border:1px solid rgba(255,255,255,.08);
    border-radius:16px;
    padding:14px;
  }

  .stat-label{
    display:flex;
    justify-content:space-between;
    margin-bottom:8px;
    color:#f1dfb2;
    font-weight:700;
  }

  .bar{
    height:12px;
    border-radius:999px;
    background:rgba(255,255,255,.08);
    overflow:hidden;
  }

  .bar-fill{
    height:100%;
    width:0%;
    border-radius:999px;
    transition:width 1.1s ease;
    box-shadow:0 0 14px currentColor;
  }

  .result-comment{
    margin-top:20px;
    font-size:1.05rem;
    line-height:1.7;
    color:#f6f0df;
  }

  .compare-box{
    margin-top:18px;
    padding:14px 16px;
    border-radius:16px;
    background:rgba(255,255,255,.04);
    border:1px solid rgba(255,255,255,.08);
    color:var(--muted);
  }

  .result-actions{
    margin-top:22px;
    display:flex;
    gap:12px;
    justify-content:center;
    flex-wrap:wrap;
  }

  @keyframes twinkle{
    0%,100%{opacity:.15; transform:scale(.7)}
    50%{opacity:1; transform:scale(1.5)}
  }

  @keyframes fadeIn{
    from{opacity:0}
    to{opacity:1}
  }

  @keyframes prophecyRise{
    from{opacity:0; transform:translateY(30px) scale(.96)}
    to{opacity:1; transform:translateY(0) scale(1)}
  }

  @keyframes fadeSoft{
    from{opacity:0; transform:translateY(6px)}
    to{opacity:1; transform:translateY(0)}
  }

  @media (max-width: 980px){
    .traits-grid{grid-template-columns:repeat(3,1fr)}
    .situations-grid{grid-template-columns:1fr}
  }

  @media (max-width: 700px){
    .traits-grid{grid-template-columns:repeat(2,1fr)}
    .stats{grid-template-columns:1fr}
    .magic-wheel{width:220px;height:220px}
  }

  @media (max-width: 560px){
    .traits-grid{grid-template-columns:1fr}
    .card-head{grid-template-columns:1fr}
    .art{
      border-left:none;
      border-top:1px solid rgba(229,208,151,.14);
      min-height:170px;
    }
  }
</style>
</head>
<body>
<div class="header-image"><div class="header-overlay"></div></div>
<div class="sparkles" id="sparkles"></div>

<div class="wrap">
  <section class="hero">
    <h1>🧠 Hra na temperament a povahu</h1>
    <div class="subtitle">
      Dva režimy, dva pohledy na osobnost: rysy povahy a reakce v situacích.
    </div>

    <div class="mode-switch-wrap">
      <span class="mode-label active" id="labelTraits">🎭 Rysy povahy</span>
      <label class="mode-toggle">
        <input type="checkbox" id="modeToggle">
        <span class="mode-slider"></span>
      </label>
      <span class="mode-label" id="labelSituations">🔮 Situace</span>
    </div>
  </section>

  <h2 class="section-title" id="mainSectionTitle">Vyber rysy, které tě nejvíc vystihují</h2>

  <section class="panel traits-panel" id="traitsPanel">
    <div class="traits-grid" id="traitsGrid"></div>
    <div class="trait-info">
      Vyber alespoň 5 rysů. Čím přesnější výběr, tím přesnější profil.
    </div>
    <div class="actions">
      <button onclick="showTraitsResult()">✨ Ukázat profil</button>
    </div>
  </section>

  <section class="panel situations-panel" id="situationsPanel">
    <div class="situations-grid" id="situationsGrid"></div>
    <div class="actions">
      <button onclick="showSituationsResult()">🔮 Odhalit temperament</button>
    </div>
  </section>

  <section class="help-box" id="helpBox">
    <h3>Jak s tím pracovat ve výuce</h3>
    <p><b>Režim A – Rysy povahy:</b> Hráč vybírá vlastnosti, které ho podle něj nejlépe vystihují.</p>
    <p><b>Režim B – Situace:</b> Hráč reaguje spontánně na různé situace. Výsledek může ukázat, jak se chová pod tlakem nebo ve skupině.</p>
    <ul>
      <li>Porovnejte: Jak se vidím × Jak jednám?</li>
      <li>Který výsledek je přesnější?</li>
      <li>Který rys nebo temperament tě překvapil?</li>
    </ul>
  </section>
</div>

<div id="resultOverlay" class="result-overlay">
  <div class="result-box">
    <h2 id="resultTitle">✨ Výsledek ✨</h2>

    <div class="wheel-wrap">
      <div id="magicWheel" class="magic-wheel">
        <div class="magic-wheel-center">
          <div class="main-role" id="mainRoleText">Tvoje role</div>
          <div class="small" id="mainRoleSub">tvůj výsledek</div>
        </div>
      </div>
    </div>

    <div class="stats" id="statsBox"></div>
    <div class="result-comment" id="resultComment"></div>
    <div class="compare-box" id="compareBox" style="display:none;"></div>

    <div class="result-actions">
      <button onclick="closeResult()">Zavřít</button>
      <button onclick="resetCurrentMode()">Zkusit znovu</button>
    </div>
  </div>
</div>

<script>
  const sparkleWrap = document.getElementById("sparkles");
  for(let i=0;i<50;i++){
    const s = document.createElement("div");
    s.className = "sparkle";
    s.style.left = Math.random()*100 + "vw";
    s.style.top = Math.random()*100 + "vh";
    s.style.animationDelay = (Math.random()*4) + "s";
    s.style.opacity = 0.15 + Math.random()*0.85;
    sparkleWrap.appendChild(s);
  }

  let mode = "traits";

  const traitProfiles = {
    leader:  { name:"Vůdce", color:"var(--leader)" },
    social:  { name:"Společník", color:"var(--social)" },
    calm:    { name:"Klidná síla", color:"var(--calm)" },
    deep:    { name:"Hloubavý typ", color:"var(--deep)" },
    creator: { name:"Tvůrce", color:"var(--creator)" },
    steady:  { name:"Vytrvalec", color:"var(--steady)" }
  };

  const traitsData = [
    { text:"Přátelský", score:{social:2} },
    { text:"Laskavý", score:{calm:2} },
    { text:"Sebevědomý", score:{leader:2} },
    { text:"Skromný", score:{calm:1, deep:1} },
    { text:"Zodpovědný", score:{steady:2} },
    { text:"Optimistický", score:{social:2} },
    { text:"Pesimistický", score:{deep:2} },
    { text:"Upřímný", score:{calm:1, steady:1} },
    { text:"Ambiciózní", score:{leader:2} },
    { text:"Trpělivý", score:{calm:2} },
    { text:"Roztěžitý", score:{social:1} },
    { text:"Hodný", score:{calm:2} },
    { text:"Tichý", score:{deep:2} },
    { text:"Nervózní", score:{deep:2} },
    { text:"Ctižádostivý", score:{leader:2} },
    { text:"Kreativní", score:{creator:3} },
    { text:"Pohodový", score:{social:1, calm:1} },
    { text:"Vytrvalý", score:{steady:3} },
    { text:"Veselý", score:{social:2} },
    { text:"Odhodlaný", score:{leader:1, steady:1} }
  ];

  const selectedTraits = new Set();
  const traitsGrid = document.getElementById("traitsGrid");

  traitsData.forEach((item, index) => {
    const btn = document.createElement("button");
    btn.className = "trait-btn";
    btn.textContent = item.text;
    btn.onclick = () => {
      if(selectedTraits.has(index)){
        selectedTraits.delete(index);
        btn.classList.remove("selected");
      } else {
        selectedTraits.add(index);
        btn.classList.add("selected");
      }
    };
    traitsGrid.appendChild(btn);
  });

  function calcTraitsScores(){
    const scores = { leader:0, social:0, calm:0, deep:0, creator:0, steady:0 };
    selectedTraits.forEach(i => {
      const item = traitsData[i];
      Object.entries(item.score).forEach(([k,v]) => scores[k] += v);
    });
    return scores;
  }

  function traitsComment(main, second){
    const mainTexts = {
      leader: "Působíš jako člověk, který chce věci posouvat dopředu. Umíš se rozhodnout, převzít iniciativu a nést odpovědnost. Často máš silnou potřebu jednat, ovlivňovat dění kolem sebe a dotahovat věci k cíli.",
      social: "Tvoje síla je v kontaktu s lidmi, energii a otevřenosti. Umíš vytvářet příjemnou atmosféru, povzbuzovat ostatní a vnášet do skupiny lehkost. Často působíš optimisticky a přirozeně navazuješ vztahy.",
      calm: "Působíš vyrovnaně, trpělivě a laskavě. Nehledáš zbytečné drama, ale spíš stabilitu a dobré vztahy. Lidé tě mohou vnímat jako člověka, na kterého je spoleh a který umí uklidnit napjatou situaci.",
      deep: "Máš silné vnitřní prožívání a vnímáš věci do hloubky. Přemýšlíš, analyzuješ a často si všimneš detailů, které ostatním uniknou. Tvoje citlivost je zároveň velká síla i oblast, která tě může dělat zranitelnější.",
      creator: "Silnou stránkou tvé osobnosti je nápaditost, originalita a chuť objevovat nové možnosti. Nepřitahuje tě jen hotové řešení, ale i samotné tvoření a hledání vlastní cesty. Často přinášíš nové pohledy a neobvyklé nápady.",
      steady: "Tvoje síla je ve spolehlivosti, zodpovědnosti a schopnosti vydržet. Když si něco vezmeš za své, umíš u toho zůstat a dotáhnout to. Působíš jako člověk, který se nevzdává snadno a umí nést dlouhodobou zátěž."
    };

    const combos = {
      "leader-social":"Máš energii člověka, který umí nejen vést, ale i strhnout ostatní. Působíš aktivně, otevřeně a přirozeně si získáváš pozornost.",
      "leader-steady":"Nejen že chceš věci posouvat dopředu, ale máš i schopnost vydržet a dotahovat je. Tvoje síla je v kombinaci rozhodnosti a vytrvalosti.",
      "leader-deep":"Na venek můžeš působit rozhodně, ale uvnitř hodně přemýšlíš a věci prožíváš do hloubky. Spojuješ akci s vnitřní reflexí.",
