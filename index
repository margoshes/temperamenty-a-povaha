  function buildConicGradient(percentScores, order){
    let current = 0;
    const parts = [];
    order.forEach(([key, color], idx) => {
      const deg = Math.round((percentScores[key] / 100) * 360);
      const end = idx === order.length - 1 ? 360 : current + deg;
      parts.push(`${color} ${current}deg ${end}deg`);
      current = end;
    });
    return `conic-gradient(${parts.join(", ")})`;
  }

